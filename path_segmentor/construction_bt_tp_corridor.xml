<?xml version="1.0"?>
<!--
  NavigateThroughPoses — corridor-aware with obstacle replanning.

  Behaviour:
  1. Clear both costmaps + compute initial global plan ONCE at mission start.
  2. PipelineSequence runs a 1 Hz path-validity monitor alongside FollowPath.
  3. Every 1 Hz the monitor checks: is the current path still free?

       YES → keep following unchanged.

       NO  → try to replan through remaining goals.
               Replan succeeds → FollowPath picks up the new local-shifted path
                                 that goes around the obstacle. Vehicle moves.
               Replan fails    → no passable route inside the corridor.
                                 BT returns FAILURE. The collision monitor has
                                 already zeroed cmd_vel_out. The FSM receives the
                                 navigation failure and handles recovery
                                 (stop / wait / alert).

  What makes this work:
  - /corridor/obstacle_cloud marks WALL pixels from path_segmentor into the
    local costmap obstacle_layer as LETHAL cells.
  - /corridor/boundary_cloud marks the corridor left+right edges as LETHAL,
    preventing the planner from routing outside the ±1 m safety zone.
  - IsPathValid checks every pose in {path} against the costmap. Any LETHAL
    cell on the path triggers a replan.
  - ComputePathThroughPoses routes around the LETHAL region. If an
    obstacle-free route exists inside the corridor, this succeeds and updates
    {path}. FollowPath picks it up on the next tick.
  - If the entire corridor is blocked, ComputePathThroughPoses fails → BT fails.

  Key difference from construction_bt_tp.xml (original):
  - Replanning is now ACTIVE (was disabled — SingleTrigger held it to one plan).
  - Local costmap now sees real obstacles from /corridor/obstacle_cloud and a
    virtual fence from /corridor/boundary_cloud.
-->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">

    <Sequence name="Navigate_Corridor">

      <!-- ── STEP 1: Clear costmaps and compute initial path ONCE ──────── -->
      <SingleTrigger name="InitialSetup">
        <Sequence name="SetupSequence">

          <RetryUntilSuccessful num_attempts="4">
            <ClearEntireCostmap name="ClearLocal"
              service_name="local_costmap/clear_entirely_local_costmap"
              server_timeout="8000"/>
          </RetryUntilSuccessful>

          <RetryUntilSuccessful num_attempts="4">
            <ClearEntireCostmap name="ClearGlobal"
              service_name="global_costmap/clear_entirely_global_costmap"
              server_timeout="8000"/>
          </RetryUntilSuccessful>

          <!-- Skip waypoints the vehicle has already passed -->
          <RemovePassedGoals input_goals="{goals}"
                             output_goals="{goals}"
                             radius="1.5"/>

          <!-- One-shot initial global plan -->
          <ComputePathThroughPoses name="InitialPlan"
                                   goals="{goals}"
                                   path="{path}"
                                   planner_id="GridBased"/>
        </Sequence>
      </SingleTrigger>

      <!-- ── STEP 2: Follow with continuous validity check + replanning ── -->
      <!--
        PipelineSequence ticks ALL currently-running children each cycle.
        This means FollowPath keeps running while the RateController checks
        the path — they run concurrently, not in series.
      -->
      <PipelineSequence name="FollowWithReplan">

        <!-- Path validity monitor at 1 Hz -->
        <RateController hz="1.0">
          <Fallback name="ValidOrReplan">

            <!-- Happy path: current path has no LETHAL cells → keep going -->
            <IsPathValid path="{path}"/>

            <!-- Path is blocked: try to compute a new route around obstacle -->
            <Sequence name="ReplanAround">
              <!-- Skip goals already reached so we only plan to remaining ones -->
              <RemovePassedGoals input_goals="{goals}"
                                 output_goals="{goals}"
                                 radius="1.5"/>
              <!--
                Recompute path. The local costmap now has:
                  - LETHAL cells from /corridor/obstacle_cloud (real obstacles)
                  - LETHAL cells from /corridor/boundary_cloud (corridor fence)
                If an obstacle-free route exists inside the corridor, this
                succeeds and updates {path}. FollowPath picks it up next tick.
              -->
              <ComputePathThroughPoses name="ReplanPath"
                                       goals="{goals}"
                                       path="{path}"
                                       planner_id="GridBased"/>
            </Sequence>

            <!--
              If BOTH branches fail:
                - IsPathValid failed (obstacle in path)
                - ComputePathThroughPoses failed (no route possible in corridor)
              Fallback → FAILURE → RateController → FAILURE →
              PipelineSequence → FAILURE → outer Sequence → FAILURE.

              At this point:
                - Collision monitor has already stopped the vehicle
                  (cmd_vel_out = 0, PolygonStop zone)
                - BT failure propagates to bt_navigator action → FAILED result
                - FSM receives navigation failure → handles stop / alert / retry
            -->

          </Fallback>
        </RateController>

        <!-- Follow the path (initial or freshly replanned) -->
        <FollowPath path="{path}"
                    controller_id="FollowPath"/>

      </PipelineSequence>

    </Sequence>

  </BehaviorTree>
</root>
